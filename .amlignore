# Azure ML uses this file instead of .gitignore when uploading code.
# external/KPGT/src/ is intentionally included (328K, needed by trainer.py).
# Large data/model dirs are excluded — they are uploaded as separate job inputs.

.env
*.pem
*.key

__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.ipynb_checkpoints/
.DS_Store
.vscode/

# Large data — uploaded as separate inputs via submit_job.py
data/toxric/
data/kpgt-cache/

# KPGT model weights — uploaded as separate input via submit_job.py
external/KPGT/models/

# Checkpoints output — written by the job, not needed as input
checkpoints/
*.ckpt

# Streamlit temp output
toxnav_*/
