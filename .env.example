# Copy this file to .env and fill in your values.
# .env is gitignored (don't commit secrets).

# === LLM — Azure OpenAI (used for orchestration, validation, suggestion, explanation) ===
# Endpoint: Azure OpenAI resource URL, e.g. https://<resource>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=""
# Deployment name of your GPT model, e.g. gpt-4o
MODEL_DEPLOYMENT="gpt-4o"
# Auth: DefaultAzureCredential (az login / managed identity) — no API key needed.

# === Phase D: Azure ML ===
AZURE_SUBSCRIPTION_ID=""
AZURE_RESOURCE_GROUP=""
AZURE_WORKSPACE_NAME=""
AZURE_COMPUTE_CLUSTER=""   # e.g. "gpu-cluster"

# === Paths (defaults are fine for local dev) ===
TOXRIC_DATA_DIR="./data/toxric"
KPGT_REPO_DIR="./external/KPGT"
KPGT_MODELS_DIR="./external/KPGT/models"
