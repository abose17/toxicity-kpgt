[Unit]
Description=KPGT-TOXRIC inference API
After=network.target

[Service]
Type=simple
User=azureuser
WorkingDirectory=/home/azureuser/toxicity-kpgt
EnvironmentFile=/home/azureuser/toxicity-kpgt/.env
ExecStart=/home/azureuser/toxicity-kpgt/.venv/bin/uvicorn serving.app:app --host 0.0.0.0 --port 8000 --workers 1
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
